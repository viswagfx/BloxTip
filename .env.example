# Roblox Open Cloud API Key
# Create at https://create.roblox.com/credentials
# Required scopes: universe.developer-product:write, universe.developer-product:read
ROBLOX_API_KEY=your_api_key_here

# Your Roblox Universe ID (found in Game Settings > Basic Info)
UNIVERSE_ID=your_universe_id_here


# Product name/description templates (optional)
# Placeholders: {amount}, {price}, {receiving}
PRODUCT_NAME_TEMPLATE=Donate {receiving} Robux
PRODUCT_DESCRIPTION_TEMPLATE=Donated {receiving} Robux via BloxTip.
